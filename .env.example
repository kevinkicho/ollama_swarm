# Historical opencode HTTP-basic-auth secret. The opencode subprocess was
# removed in E3 Phase 5 (2026-04-29) and nothing reads this value at runtime,
# but config.ts still validates that it's non-empty so existing setups don't
# break. Set to any non-empty string.
OPENCODE_SERVER_PASSWORD=please-change-me

# Ollama (OpenAI-compatible) endpoint — defaults to localhost:11434/v1.
# The provider stack normalizes a trailing /v1 defensively, so either form works.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Default model every spawned agent will use when the form leaves the model
# field blank. For paid providers use the prefixed form, e.g.
# anthropic/claude-opus-4-7 or openai/gpt-5.
DEFAULT_MODEL=glm-5.1:cloud

# Optional API keys for paid providers. The setup form's provider tabs
# grey out the matching tab when unset.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional Ollama Cloud key (https://docs.ollama.com/cloud, key from
# ollama.com/settings/keys). The Ollama Cloud tab is always usable —
# the local Ollama install proxies :cloud models to ollama.com when an
# account is configured locally — but setting this key surfaces the
# "live key configured" hint in the provider tab tooltip.
OLLAMA_API_KEY=

# Backend HTTP + WS port. Defaults to 8243 (pinned in scripts/dev.mjs).
# Set to override; leave blank to use the default.
SERVER_PORT=

# Vite dev-server port. Defaults to 8244 (pinned in scripts/dev.mjs).
# Set to override; leave blank to use the default.
WEB_PORT=

# Optional — only needed for cloning private GitHub repos.
GITHUB_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Reliability flags (R1-R17, 2026-05-04). All default OFF. Each
# corresponds to a helper in server/src/swarm/ — see docs/STATUS.md
# for the full table.
# ─────────────────────────────────────────────────────────────────────

# R6: drain-by-default stop. When ON, the first /api/swarm/stop click
# drains the run (finish current turn, then stop); a second click
# within 5s hard-kills. Default OFF preserves single-click hard-kill.
SWARM_DRAIN_ON_STOP=false

# R5: auto-resume mid-flight runs from disk at server startup. When
# ON, the server scans known parent dirs for run-state.json snapshots
# and auto-restarts ones that pass the freshness/size policy
# (≤30 min old, ≤1000 transcript entries, has runConfig). Default OFF.
SWARM_AUTO_RESUME=false

# R13: memory-pressure backpressure. When ON, BlackboardRunner
# samples heap on every cap-watchdog tick (5s). Workers idle on
# crossing into the 90% pressure level; resume when heap drops back
# to ok.
SWARM_MEMORY_BACKPRESSURE=false

# R9: semantic-loop detector. When ON, the runner evaluates Jaccard
# similarity over the last 4 agent turns after each turn. On detected
# loop, emits a transcript warning. After 3 consecutive detections,
# halts the run gracefully with terminationReason="loop-detected".
SWARM_LOOP_DETECTION=false

# R7: pause workers when WS subscriber count drops to 0. Resume on
# first reconnect (unless quota / user-paused). Useful for
# interactive sessions where browser-close should stop spending
# tokens; could break headless callers that legitimately never
# connect. Default OFF.
SWARM_PAUSE_ON_DISCONNECT=false

# R1: provider failover chain. Comma-separated provider-prefixed
# model strings. When the active model hits a quota/auth wall, the
# runner swaps to the next model in the list. Per-run override via
# RunConfig.providerFailover (or the SetupForm "Failover chain"
# input) wins over this default.
# Example: SWARM_PROVIDER_FAILOVER=anthropic/claude-haiku-4-5,glm-5.1:cloud
SWARM_PROVIDER_FAILOVER=

# R3: when the cloud failover chain is exhausted, fall back to a
# locally-pulled Ollama tag (discovered via /api/tags at run-start).
# Default OFF.
SWARM_DEGRADATION_FALLBACK=false

# R3: preferred local-tag order for degradation. Comma-separated.
# When unset, pickLocalFallback chooses the largest tag by inferred
# parameter count.
# Example: SWARM_DEGRADATION_PREFERRED=mistral:7b,llama3:8b
SWARM_DEGRADATION_PREFERRED=

# R10: proactive model-health swap. When ON, before each prompt the
# runner evaluates the active model's recent success rate (sliding
# window of 10, threshold 50% over ≥5 samples). Degraded models are
# swapped pre-flight. Default OFF.
SWARM_MODEL_HEALTH_SWAP=false
