# HTTP basic auth shared by every opencode serve process on this machine
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=

# Ollama (OpenAI-compatible) endpoint — used when writing opencode.json into the clone
OLLAMA_BASE_URL=http://localhost:11434/v1

# Default model every spawned agent will use.
# 2026-04-27 (afternoon): reverted from deepseek-v4-pro:cloud → glm-5.1:cloud
# after deepseek showed Ollama server-traffic congestion (HTTP 503 + slow
# tool-call shape). nemotron-3-super:cloud and deepseek-v4-pro:cloud both
# remain available — type explicitly into the form/API to use either.
DEFAULT_MODEL=glm-5.1:cloud

# Path to the opencode CLI. Leave blank to use whatever's on PATH.
OPENCODE_BIN=opencode

# Backend HTTP + WS port. Defaults to 8243 (pinned in scripts/dev.mjs).
# Set to override; leave blank to use the default.
SERVER_PORT=

# Vite dev-server port. Defaults to 8244 (pinned in scripts/dev.mjs).
# Set to override; leave blank to use the default.
WEB_PORT=

# Optional — only needed for cloning private GitHub repos
GITHUB_TOKEN=
