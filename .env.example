# Historical opencode HTTP-basic-auth secret. The opencode subprocess was
# removed in E3 Phase 5 (2026-04-29) and nothing reads this value at runtime,
# but config.ts still validates that it's non-empty so existing setups don't
# break. Set to any non-empty string.
OPENCODE_SERVER_PASSWORD=please-change-me

# Ollama (OpenAI-compatible) endpoint — defaults to localhost:11434/v1.
# The provider stack normalizes a trailing /v1 defensively, so either form works.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Default model every spawned agent will use when the form leaves the model
# field blank. For paid providers use the prefixed form, e.g.
# anthropic/claude-opus-4-7 or openai/gpt-5.
DEFAULT_MODEL=glm-5.1:cloud

# Optional API keys for paid providers. The setup form's provider tabs
# grey out the matching tab when unset.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional Ollama Cloud key (https://docs.ollama.com/cloud, key from
# ollama.com/settings/keys). The Ollama Cloud tab is always usable —
# the local Ollama install proxies :cloud models to ollama.com when an
# account is configured locally — but setting this key surfaces the
# "live key configured" hint in the provider tab tooltip.
OLLAMA_API_KEY=

# Backend HTTP + WS port. Defaults to 8243 (pinned in scripts/dev.mjs).
# Set to override; leave blank to use the default.
SERVER_PORT=

# Vite dev-server port. Defaults to 8244 (pinned in scripts/dev.mjs).
# Set to override; leave blank to use the default.
WEB_PORT=

# Optional — only needed for cloning private GitHub repos.
GITHUB_TOKEN=
